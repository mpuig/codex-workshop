  "fraud_indicators": {
    "description": "Red flags that should trigger routing to fraud-investigation path. A single indicator raises a flag; two or more indicators mandate SIU referral.",
    "indicators": [
      {
        "id": "FI-001",
        "name": "Multiple recent claims",
        "description": "Policyholder has filed 2 or more claims within the last 90 days.",
        "severity": "High"
      },
      {
        "id": "FI-002",
        "name": "New policy claim",
        "description": "Claim filed within 90 days of policy inception or last renewal.",
        "severity": "Medium"
      },
      {
        "id": "FI-003",
        "name": "Inflated estimate",
        "description": "Estimated claim amount exceeds 80% of the insured value for the item.",
        "severity": "High"
      },
      {
        "id": "FI-004",
        "name": "Delayed reporting",
        "description": "More than 30 days between incident_date and claim_date.",
        "severity": "Medium"
      },
      {
        "id": "FI-005",
        "name": "No police report for theft/vandalism",
        "description": "Theft or vandalism claim filed without a police report.",
        "severity": "High"
      },
      {
        "id": "FI-006",
        "name": "Inconsistent description",
        "description": "Incident description does not match the incident_type or claimed damages.",
        "severity": "High"
      },
      {
        "id": "FI-007",
        "name": "Holiday/weekend clustering",
        "description": "Incident occurred during a major holiday or long weekend when verification is harder.",
        "severity": "Low"
      },
      {
        "id": "FI-008",
        "name": "Round number estimate",
        "description": "Estimated amount is a suspiciously round number (e.g., exactly 10000, 25000, 50000).",
        "severity": "Low"
      },
      {
        "id": "FI-009",
        "name": "Prior fraud history",
        "description": "Policyholder has a previously denied claim due to fraud suspicion.",
        "severity": "Critical"
      },
      {
        "id": "FI-010",
        "name": "Third-party only witness",
        "description": "The only witnesses are related to or known associates of the claimant.",
        "severity": "Medium"
      }
    ]
  },


  "priority_rules": {
    "description": "Determines the priority level for a claim based on estimated amount, injury involvement, and incident characteristics. Rules are evaluated top-to-bottom; the first matching rule wins.",
    "levels": [
      {
        "priority": "Critical",
        "color_code": "#DC2626",
        "conditions_any_of": [
          "estimated_amount_eur > 50000",
          "injury_reported == 'Yes' AND estimated_amount_eur > 10000",
          "incident_type == 'fire' AND product_line == 'Commercial'",
          "incident_type == 'medical_emergency' AND estimated_amount_eur > 15000",
          "incident_type == 'hospitalization'"
        ],
        "response_time_hours": 4,
        "description": "Requires immediate senior adjuster attention. Must be acknowledged within 4 hours."
      },
      {
        "priority": "High",
        "color_code": "#F59E0B",
        "conditions_any_of": [
          "estimated_amount_eur > 20000",
          "injury_reported == 'Yes'",
          "incident_type == 'fire'",
          "incident_type == 'theft' AND estimated_amount_eur > 10000",
          "incident_type IN ('slip_and_fall', 'product_liability', 'professional_negligence')",
          "category == 'auto-bodily-injury'"
        ],
        "response_time_hours": 24,
        "description": "High value or injury-related claims. Must be acknowledged within 24 hours."
      },
      {
        "priority": "Medium",
        "color_code": "#3B82F6",
        "conditions_any_of": [
          "estimated_amount_eur BETWEEN 5000 AND 20000",
          "incident_type == 'water_damage'",
          "incident_type == 'storm_damage'",
          "police_report_filed == 'Yes'"
        ],
        "response_time_hours": 48,
        "description": "Standard claims requiring normal processing. Must be acknowledged within 48 hours."
      },
      {
        "priority": "Low",
        "color_code": "#10B981",
        "conditions_any_of": [
          "estimated_amount_eur < 5000",
          "incident_type IN ('glass_damage', 'dental', 'physiotherapy', 'outpatient_treatment')"
        ],
        "response_time_hours": 72,
        "description": "Routine low-value claims. Can be processed in standard queue within 72 hours."
      }
    ]
  },

  "handling_paths": {
    "description": "Determines the processing path for each claim based on category, priority, and other factors.",
    "paths": [
      {
        "path": "fast-track",
        "description": "Automated or semi-automated processing with minimal manual review. Target: resolved within 5 business days.",
        "criteria": [
          "priority == 'Low' AND estimated_amount_eur < 2000",
          "incident_type == 'glass_damage'",
          "incident_type IN ('dental', 'physiotherapy', 'outpatient_treatment') AND estimated_amount_eur < 3000",
          "incident_type == 'water_damage' AND estimated_amount_eur < 5000 AND no_fraud_indicators"
        ],
        "approval_authority": "Automated / Junior Adjuster",
        "max_payout_without_escalation_eur": 3000
      },
      {
        "path": "standard",
        "description": "Normal processing with adjuster review, documentation collection, and assessment. Target: resolved within 15 business days.",
        "criteria": [
          "priority IN ('Low', 'Medium') AND NOT fast-track eligible",
          "auto-property claims < 20000 EUR",
          "home-water-damage claims < 15000 EUR",
          "health-routine claims of any amount"
        ],
        "approval_authority": "Mid-level Adjuster",
        "max_payout_without_escalation_eur": 15000
      },
      {
        "path": "complex-review",
        "description": "Multi-party or high-value claims requiring senior review, possibly external assessors. Target: resolved within 30 business days.",
        "criteria": [
          "priority IN ('High', 'Critical')",
          "estimated_amount_eur > 20000",
          "incident_type == 'fire'",
          "multiple parties involved",
          "commercial-liability claims",
          "auto-bodily-injury with estimated_amount > 15000"
        ],
        "approval_authority": "Senior Adjuster / Claims Manager",
        "max_payout_without_escalation_eur": 75000
      },
      {
        "path": "fraud-investigation",
        "description": "Claims flagged by fraud indicators. Routed to the Special Investigations Unit (SIU). Target: investigation within 45 business days.",
        "criteria": [
          "any fraud indicator triggered (see fraud_indicators section)",
          "inconsistent documentation",
          "claimant has history of denied claims"
        ],
        "approval_authority": "SIU Manager",
        "max_payout_without_escalation_eur": 0
      },
      {
        "path": "legal-referral",
        "description": "Claims involving legal complexity, third-party liability disputes, or regulatory concerns. Target: legal review within 10 business days.",
        "criteria": [
          "commercial-liability with injury_reported == 'Yes'",
          "professional_negligence claims",
          "claims where policyholder has retained legal counsel",
          "estimated_amount_eur > 100000",
          "auto-bodily-injury with disputed liability"
        ],
        "approval_authority": "Legal Department / External Counsel",
        "max_payout_without_escalation_eur": 0
      }
    ]
  },

